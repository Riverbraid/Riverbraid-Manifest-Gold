{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["repo", "version", "role", "status", "authority"],
  "properties": {
    "repo": { "type": "string" },
    "version": { "type": "string" },
    "role": { "type": "string" },
    "status": { "enum": ["active", "parked", "experimental", "deprecated", "archived"] },
    "authority": { "enum": ["normative", "verifier", "support", "informative", "none"] }
  }
}
